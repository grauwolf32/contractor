  dynamic buildRun {
    title "Dynamic — build pipeline run"

    user -> cli "Invoke `contractor --workflow oas_build`"
    cli -> pipelineRegistry "Resolve build workflow"
    pipelineRegistry -> buildPipeline "Construct OasBuildingWorkflow"
    buildPipeline -> taskRunner "Enqueue dependency_information"
    buildPipeline -> taskRunner "Enqueue project_information"
    buildPipeline -> taskRunner "Enqueue oas_update (multi-iteration)"
    buildPipeline -> taskRunner "Enqueue oas_validate"
    taskRunner -> runnerCore "Run planning agent as root"
    runnerCore -> planningAgent "Execute subtask state machine"
    planningAgent -> workerAdapter "Delegate current subtask"
    workerAdapter -> sweAgent "Analyse codebase (dependency/project tasks)"
    workerAdapter -> oasBuilderAgent "Build/update OpenAPI schema (oas_update task)"
    sweAgent -> fsTools "Explore repository"
    sweAgent -> memoryTools "Record findings"
    oasBuilderAgent -> openapiTools "Persist schema updates"
    oasBuilderAgent -> memoryTools "Record rationale"
    taskRunner -> artifactStore "Save result/summary/records"
    cli -> outputDir "Export artifacts and metrics.jsonl"
  }

  dynamic traceRun {
    title "Dynamic — trace pipeline run (planner-driven)"

    user -> cli "Invoke `contractor --workflow trace --artifact openapi.yaml`"
    cli -> pipelineRegistry "Resolve trace workflow"
    pipelineRegistry -> tracePipeline "Construct TraceAnnotationWorkflow"
    tracePipeline -> artifactStore "Load oas-openapi-building"
    tracePipeline -> overlayfs "Initialise memory overlay over project"
    tracePipeline -> taskRunner "Per-path: queue trace_annotation per operation"
    taskRunner -> runnerCore "Run planning agent as root"
    runnerCore -> planningAgent "Execute subtask state machine"
    planningAgent -> workerAdapter "Delegate trace_annotation subtask"
    workerAdapter -> traceAgent "Invoke trace worker for current operation"
    traceAgent -> fsTools "Explore codebase via overlay"
    traceAgent -> fsTools "Insert @trace / @validate / @sink annotations"
    traceAgent -> vulnTools "report_vulnerability when sink path confirmed"
    traceAgent -> memoryTools "Record findings"
    traceAgent -> overlayfs "Buffer annotation writes in-memory"
    tracePipeline -> artifactStore "Save trace-<ns>-fs overlay state"
    tracePipeline -> artifactStore "Save trace-<ns>-diff unified diff"
    cli -> outputDir "Export annotation diffs and metrics.jsonl"
  }

  dynamic traceDirectRun {
    title "Dynamic — trace-direct / trace-graph run"

    user -> cli "Invoke `contractor --workflow trace-direct` (or trace-graph)"
    cli -> pipelineRegistry "Resolve direct trace workflow"
    pipelineRegistry -> traceDirectPipeline "Construct TraceAnnotationDirectWorkflow"
    traceDirectPipeline -> artifactStore "Load oas-openapi-building"
    traceDirectPipeline -> overlayfs "Initialise memory overlay"
    traceDirectPipeline -> agentRunner "Per-operation: invoke trace_agent directly"
    agentRunner -> runnerCore "Run trace_agent as root (no planner)"
    runnerCore -> traceAgent "Execute single agent loop"
    traceAgent -> fsTools "Read + annotate via overlay"
    traceAgent -> vulnTools "report_vulnerability when sink path confirmed"
    traceAgent -> overlayfs "Buffer writes in-memory"
    traceDirectPipeline -> artifactStore "Save trace-<ns>-fs / trace-<ns>-diff per path"
    cli -> outputDir "Export annotation diffs and metrics.jsonl"
  }

  dynamic traceVerifyRun {
    title "Dynamic — trace-verify run (Stage-2 verifier)"

    user -> cli "Invoke `contractor --workflow trace-verify --artifact openapi.yaml`"
    cli -> pipelineRegistry "Resolve trace-verify workflow"
    pipelineRegistry -> traceVerifyPipeline "Construct TraceVerifyWorkflow"
    traceVerifyPipeline -> artifactStore "Load per-path VulnerabilityReports from prior trace run"
    traceVerifyPipeline -> taskRunner "Per-finding: queue trace_verify task"
    taskRunner -> runnerCore "Run planning agent with trace_verifier_agent as worker"
    runnerCore -> planningAgent "Execute subtask state machine"
    planningAgent -> workerAdapter "Delegate verify subtask"
    workerAdapter -> traceVerifierAgent "Static, read-only verifier"
    traceVerifierAgent -> fsTools "Read source as evidence"
    traceVerifierAgent -> vulnTools "verify_finding (paired with upstream report by namespace)"
    taskRunner -> artifactStore "Save result/summary/records + VerifiedFinding"
    cli -> outputDir "Export verdicts and metrics.jsonl"
  }

  dynamic memoryHandoffRun {
    title "Dynamic — cross-task artifact handoff"

    taskRunner -> artifactStore "Load upstream task artifacts"
    taskRunner -> pipelineArtifacts "Convert artifacts to memory notes"
    pipelineArtifacts -> memoryTools "Inject notes tagged inbox/previous-task-result"
    taskRunner -> runnerCore "Run planning agent with injected memory context"
    runnerCore -> planningAgent "Planner reads prior-task context from memory"
    planningAgent -> workerAdapter "Delegate subtask to appropriate worker"
  }

  dynamic instrumentationFlow {
    title "Dynamic — execution tracing and metrics"

    cli -> taskRunner "Register on_event handler"
    taskRunner -> runnerCore "Attach plugins"
    runnerCore -> tracePlugin "Emit trace callbacks (before/after run and tool)"
    runnerCore -> metricsPlugin "Emit Agio events (tool_call / tool_result / llm_usage / run_summary)"
    taskRunner -> cli "Surface normalised events"
    cli -> outputDir "Write metrics.jsonl and exported artifacts"
  }
}

// Notes:
// 1. The planning agent is the root agent for every TaskRunner-driven pipeline
//    (oas_build, oas_update, likec4, trace, trace-verify, router). It always sits between
//    the TaskRunner and the worker agents.
// 2. `trace-direct` and `trace-graph` bypass the planner entirely — they use the
//    bare `AgentRunner` (`contractor/runners/agent_runner.py`) and run `trace_agent`
//    directly, one invocation per OpenAPI operation. `trace-graph` is the
//    production default for the trace family (same quality as the prompt-only
//    baseline on small fixtures, materially better on large ones).
// 3. The `code_graph_agent` has been retired; its graph capabilities now ship as
//    per-agent opt-in tools (`attach_graph_tools_if_local` / `with_graph_tools=True`).
// 4. `trace-verify` is downstream of `trace` / `trace-direct`. The verifier is
//    code-evidence-only (no HTTP probes) and cannot author new findings.
// 5. `oasAnalyzer` (SequentialAgent) remains present but is not on any primary CLI path.
// 6. This file is hand-authored architecture documentation, not generated by the
//    repo's own LikeC4 tooling (which is a real working pipeline now).
