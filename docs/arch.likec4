specification {
  element person
  element system
  element container
  element component
  element storage
}

model {
  user = person "CLI User" {
    description "Developer/operator invoking contractor against a local codebase."
  }

  contractor = system "Contractor" {
    description "LLM-assisted CLI for building, enriching, and security-tracing OpenAPI specifications from source code."

    cli = container "CLI" {
      technology "Python + Click"
      description '''
- Entry point exposed as the `contractor` command.
- Accepts project path, model, workflow selection (`--workflow`), optional artifact, folder name, prompt, output directory.
- Validates input paths; `--artifact` is optional — workflows that need a seed can reuse one already in the artifact store.
- Resolves the selected model/provider route through LiteLLM-compatible configuration.
- Builds the workflow by selecting a `Workflow` subclass from the registry and constructing a `WorkflowContext`.
- Registers on_event handlers so emitted runner/plugin events can be normalised and exported.
- Writes final artifacts and metrics.jsonl to the output directory after the run completes.
'''
    }

    pipelineRegistry = component "Pipeline Registry" {
      technology "Python class registry"
      description '''
- Maps workflow names to `Workflow` subclasses (`contractor/workflows/__init__.py::get_workflows`).
- Current workflows:
    `oas_build`           → `OasBuildingWorkflow`
    `oas_update`          → `OasEnrichmentWorkflow`
    `exploit`             → `ExploitabilityWorkflow`        (per-finding live verification)
    `likec4`              → `LikeC4BuildingWorkflow`
    `trace`               → `TraceAnnotationWorkflow`       (planner-driven)
    `trace-direct`        → `TraceAnnotationDirectWorkflow` (single-agent, AgentRunner)
    `trace-graph`         → `TraceGraphWorkflow`            (trace-direct + graph tools)
    `trace-graph-pathpar` → `TraceGraphPathParWorkflow`     (trace-graph, paths in parallel)
    `trace-verify`        → `TraceVerifyWorkflow`           (per-finding static verifier)
    `vuln-assess`         → `VulnAssessWorkflow`            (discovery → OAS → trace → exploit)
    `vuln-scan`           → `VulnScanWorkflow`
    `vuln-scan-fast`      → `VulnScanFastWorkflow`          (high-recall scan → dedup → confirm)
    `vuln-scan-trace`     → `VulnScanTraceWorkflow`
    `router`              → `RouterWorkflow`                (prompt-driven dispatcher)
'''
    }

    buildPipeline = component "Build Pipeline" {
      technology "Task queue (TaskRunner)"
      description '''
- Adds `dependency_information` task using SWE worker.
- Adds `project_information` task using SWE worker with dependency artifact as input.
- Adds `oas_update` task using OAS builder worker with multiple iterations and upstream artifacts.
- Adds `oas_validate` task using the OAS linter worker as a verification pass.
'''
    }

    enrichPipeline = component "Enrich Pipeline" {
      technology "Task queue (TaskRunner)"
      description '''
- Optionally pre-saves user-supplied OpenAPI text as `oas-openapi-building` artifact.
- Adds `oas_enrich` task using OAS builder worker.
- Adds `oas_validate` task using the OAS linter worker as a verification pass.
'''
    }

    likec4Pipeline = component "LikeC4 Pipeline" {
      technology "Task queue (TaskRunner) + shared overlay"
      description '''
- Builds a LikeC4 architecture model focused on security-relevant facts
  (external interactions, trust boundaries, data classes).
- Stages: `dependency_information` (SWE) → `project_information` (SWE) →
  `likec4_build` (LikeC4 builder) → `likec4_validate` (LikeC4 builder, repair-only).
- Persists the LikeC4 source as a single text artifact (`likec4-architecture.c4`)
  via a shared overlay file at `contractor.tools.likec4.DEFAULT_LIKEC4_PATH`.
  The overlay is seeded from the artifact at start and saved back at end so reruns resume.
'''
    }

    tracePipeline = component "Trace Pipeline" {
      technology "TaskRunner per operation (planner-driven)"
      description '''
- `TraceAnnotationWorkflow`: full planner+worker stack — for each OpenAPI path it
  spawns a `TaskRunner` and adds a `trace_annotation` task per operation.
- The TaskRunner runs the planning agent as root; the planner delegates annotation
  subtasks to the trace agent (wrapped as a tool via workerAdapter).
- The trace agent annotates code with `@trace`, `@validate`, and `@sink` markers
  and reports vulnerabilities when a tainted-input → sink path is confirmed.
- After each path, saves the MemoryOverlayFileSystem state and a unified diff as
  artifacts (`trace-<ns>-fs`, `trace-<ns>-diff`).
- Operates on an in-memory overlay so the target codebase is never written to directly.
'''
    }

    traceDirectPipeline = component "Trace-Direct Pipeline" {
      technology "AgentRunner per operation (single-agent)"
      description '''
- `TraceAnnotationDirectWorkflow`: bypasses the planner entirely.
- One `trace_agent` invocation per OpenAPI operation, driven by `AgentRunner`.
- Same overlay / artifact contract as `trace`, but cheaper and faster
  because there is no planner loop or subtask state machine.
'''
    }

    traceGraphPipeline = component "Trace-Graph Pipeline" {
      technology "AgentRunner + trailmark call-graph tools"
      description '''
- `TraceGraphWorkflow`: thin variant of `trace-direct` that constructs
  `trace_agent` with `with_graph_tools=True`.
- Trailmark parses the project lazily on the first agent call and the
  cached engine is reused across operations.
- Used as the production default for the trace family — same quality as
  the prompt-only baseline on small fixtures, materially better on large ones.
'''
    }

    traceVerifyPipeline = component "Trace-Verify Pipeline" {
      technology "TaskRunner — per-finding fan-out"
      description '''
- `TraceVerifyWorkflow` (OpenAnt Stage-2 style): downstream of `trace` / `trace-direct`.
- For each OpenAPI path, loads the per-path `VulnerabilityReport` artifact and queues
  one task per finding for `trace_verifier_agent`.
- Verifier is code-evidence-only — no HTTP probes.
- Verdicts persist alongside the upstream findings under matching namespaces:
    `user:vulnerability-reports/trace-annotation:openapi:{path_key}`
    `user:vulnerability-verifications/trace-annotation:openapi:{path_key}`
'''
    }

    routerPipeline = component "Router Pipeline" {
      technology "Planner with router agent as worker"
      description '''
- Prompt-driven mode: skips the templated task queue.
- Runs a single planner whose worker is the `router_agent`, which dispatches to one of
  several specialised sub-agents (SWE, OAS builder, OAS linter, trace, HTTP).
- `--prompt` is the task objective; if omitted an interactive prompt opens.
'''
    }

    taskRunner = container "TaskRunner" {
      technology "Google ADK Runner + custom orchestration"
      description '''
- Per-task state machine: render → spawn planner+worker → iterate up to `iterations`
  successful runs → persist artifacts → emit `TaskRunnerEvent`s.
- Owns task queue entries with name, worker builder, params, required artifacts,
  iterations, attempts, steps, namespace, and model.
- Loads required upstream artifacts and injects their text as memory notes tagged
  `inbox` / `previous-task-result` in the planner's namespace.
- Always runs the planning agent as the root agent through ADK Runner.
- Collects event streams from trace and metrics plugins.
- Persists `result`, `summary`, and `records` artifacts after each task.
- Used by `oas_build`, `oas_update`, `likec4`, `trace`, `trace-verify`, and `router`.
'''
    }

    agentRunner = container "AgentRunner" {
      technology "Bare single-agent ADK Runner"
      description '''
- Minimal runner for a single `LlmAgent` invocation: no planner, no subtask state machine.
- Renders one task template, attaches metrics/trace plugins, runs the agent once
  against an ADK session, returns the final response.
- Used by `trace-direct`, `trace-graph`, and `trace-graph-pathpar` (one invocation
  per OpenAPI operation) and by `router` for the trailing free-form router run.
'''
    }

    planningAgent = container "Planning Agent" {
      technology "Google ADK LlmAgent + LiteLLM"
      description '''
- Root agent for every TaskRunner-driven pipeline (oas_build, oas_update, likec4,
  trace, trace-verify, router).
- Strict subtask state machine: add → execute → done | incomplete | malformed | skipped.
- On incomplete/malformed: must call `decompose_subtask` (1-3 children) — silent retries
  are forbidden.
- Delegates each subtask to a worker agent via workerAdapter; results are parsed
  deterministically into `SubtaskExecutionResult`.
- Reads and writes shared working memory via memory tools.
- Calls `finish` with result + summary only when the global objective is satisfied
  and no subtask is still `new`. After `finish`, the invocation is forcibly ended.
'''
    }

    traceAgent = container "Trace Agent" {
      technology "Google ADK LlmAgent + LiteLLM"
      description '''
- Worker specialised in execution-path tracing and security annotation.
- Used as a worker inside the `trace` pipeline (planner-driven) AND as a standalone
  agent inside `trace-direct` / `trace-graph` (via AgentRunner).
- Receives a subtask with an OpenAPI `operation_id` and operation schema.
- Traces the request execution path through the codebase (max 3 calls deep).
- Inserts `@trace`, `@validate`, `@sink` markers using dedicated annotation tools.
- Reports vulnerabilities (SQL injection, RCE, SSRF, IDOR, BAC, …) only when a
  concrete tainted-input → sink path is confirmed by code evidence.
- Operates on MemoryOverlayFileSystem so all writes are buffered in memory.
- Tool surface:
    fs read     — `ls`, `glob`, `grep`, `read_file`, `search_def`
    annotation  — `annotate_trace`, `annotate_validate`, `annotate_sink`
    memory      — `append_memory`, `read_memory`, `write_memory`, `list_memories`,
                  `list_tags`, `interaction_stats`
    coverage    — `list_touched_files`, `list_untouched_files`, `list_match_only_files`
    vuln        — `report_vulnerability`, `list_vulnerabilities`
    graph (opt) — `call_graph`, `callers_of`, `callees_of` (enabled by `with_graph_tools`
                  in `build_trace_agent`; default in `trace-graph`)
'''
    }

    traceVerifierAgent = container "Trace Verifier Agent" {
      technology "Google ADK LlmAgent + LiteLLM"
      description '''
- Static, code-evidence-only verifier of upstream trace findings (OpenAnt Stage-2 style).
- Reads, never writes, source code. Cannot author new findings — `report_vulnerability`
  is filtered out of its tool set (`_READ_ONLY_VULN_TOOL_NAMES`).
- Produces a structured `VerifiedFinding` verdict via `verification_tools`, paired
  by namespace with the upstream `VulnerabilityReport`.
'''
    }

    sweAgent = container "SWE Agent" {
      technology "Google ADK LlmAgent + LiteLLM"
      description '''
- Worker for read-only file-system exploration and dependency/project analysis.
- Uses fs tools (`ls`, `glob`, `grep`, `read_file`, `search_def`) to inspect the codebase.
- Records findings via memory tools.
- Invoked by the planning agent through the worker adapter.
'''
    }

    sweEditAgent = container "SWE Edit Agent" {
      technology "Google ADK LlmAgent + LiteLLM"
      description '''
- Sibling of SWE Agent with write tools (`insert_line`, `edit`, `replace_range`) enabled.
- Reserved for tasks that need source-level edits beyond the trace annotation set
  (e.g. router-dispatched code changes).
'''
    }

    oasBuilderAgent = container "OAS Builder Agent" {
      technology "Google ADK LlmAgent + LiteLLM"
      description '''
- Worker specialised in constructing and updating OpenAPI specifications.
- Reads code evidence via fs tools and applies structured schema updates via openapi tools.
- Records rationale and evidence in memory tools.
'''
    }

    oasLinterAgent = container "OAS Linter Agent" {
      technology "Google ADK LlmAgent + LiteLLM"
      description "Worker that audits the evolving OpenAPI artifact for schema consistency and gaps; one of the router's downstream sub-agents."
    }

    likec4BuilderAgent = container "LikeC4 Builder Agent" {
      technology "Google ADK LlmAgent + LiteLLM"
      description '''
- Worker that authors and validates the LikeC4 architecture file.
- Uses likec4 tools to read / write the overlay-backed `architecture.c4` plus the
  standard fs and memory tools for evidence and rationale.
'''
    }

    httpAgent = container "HTTP Agent" {
      technology "Google ADK LlmAgent + LiteLLM"
      description "Worker that issues HTTP probes via the http tool. Available to the router; not on the build/enrich/trace path."
    }

    routerAgent = container "Router Agent" {
      technology "Google ADK LlmAgent + LiteLLM"
      description '''
- Free-form dispatcher used by the `router` pipeline.
- Wraps the available worker agents (SWE, OAS builder, OAS linter, trace, HTTP)
  as AgentTools and picks the right one (or several) for the user's prompt.
- Invoked as the planner's worker via workerAdapter; the planner still owns
  subtask state.
'''
    }

    oasAnalyzer = component "OAS Analyzer" {
      technology "Google ADK SequentialAgent"
      description '''
- Sequential agent that reviews an existing OpenAPI schema.
- Produces: service name/description/summary, data-flow diagram (Mermaid), criticality rating,
  and a list of endpoint vulnerabilities with severity and confidence scores.
- Not on the primary CLI pipelines; invoked as an independent analysis step.
- Reads from and emits reports to the artifact store.
'''
    }

    workerAdapter = component "Worker-as-Tool Adapter" {
      technology "AgentTool wrapper + instrument_worker"
      description '''
- Wraps a worker agent (SWE, SWE Edit, OAS Builder, OAS Linter, Trace, Trace Verifier,
  LikeC4 Builder, HTTP, Router) so the planning agent can invoke it via tool semantics.
- `instrument_worker` attaches `input_schema = Subtask` and
  `output_schema = SubtaskExecutionResult`, plus a worker-instruction trailer to the
  worker's prompt — so any agent in the repo can be used as a worker with no glue.
'''
    }

    taskTools = component "Task Tools" {
      technology "Python functions registered as ADK tools"
      description '''
- Implements the streamline subtask state machine consumed by the planning agent.
- Tools: `add_subtask`, `execute_current_subtask`, `decompose_subtask`,
  `get_records`, `skip`, `finish`.
- Enforces `SUBTASK_STATUS_TRANSITIONS` (e.g. `incomplete` / `malformed` can only be
  decomposed or skipped, never re-executed in place).
- Owns the streamline summarizer sub-agent used by `finish`.
'''
    }

    memoryTools = component "Memory Tools" {
      technology "ADK artifact-backed memory"
      description '''
- Provides read/write/append/list operations on named memory notes.
- Backed by the artifact store, so memory persists across iterations of the same task.
- Used to pass context between planning agent and worker agents, and as the carrier
  for `inbox` (upstream artifacts) and `skill` (markdown reference bundles) injections.
'''
    }

    fsTools = component "File System Tools" {
      technology "RootedLocalFileSystem / MemoryOverlayFileSystem"
      description '''
- Read: `ls`, `glob`, `grep`, `read_file`, `search_def`.
- Write (where allowed): `insert_line`, `edit`, `replace_range`, plus the trace-specific
  `annotate_trace` / `annotate_validate` / `annotate_sink`.
- Filesystem is always sandboxed: oas_build/oas_update/likec4/router see a `RootedLocalFileSystem`;
  the trace family additionally wraps it in `MemoryOverlayFileSystem` so writes are
  captured as an artifact diff and never reach the host tree.
- Optional graph tools (`call_graph`, `callers_of`, `callees_of`) are attached on
  request via `attach_graph_tools_if_local`; they are the per-agent successor of the
  retired `code_graph_agent`.
'''
    }

    openapiTools = component "OpenAPI Tools" {
      technology "Structured YAML/JSON manipulation"
      description '''
- Provides read and structured-update operations on the evolving OpenAPI artifact.
- Ensures schema changes are applied consistently and persisted to the artifact store.
'''
    }

    vulnTools = component "Vulnerability Tools" {
      technology "Python tools backed by the artifact store"
      description '''
- `vulnerability_report_tools`: `report_vulnerability`, `list_vulnerabilities` — used
  by the trace agent to author `VulnerabilityReport`s.
- `verification_tools`: `verify_finding`, `list_verifications` — used by the trace
  verifier agent to author `VerifiedFinding`s paired with upstream reports by namespace.
- Both sets persist under `user:vulnerability-{reports,verifications}/{namespace}` in
  the artifact store.
'''
    }

    overlayfs = storage "Memory Overlay Filesystem" {
      technology "MemoryOverlayFileSystem (in-memory)"
      description '''
- In-memory copy-on-write layer over the target project directory.
- Used by the trace family and the likec4 pipeline so annotation/architecture writes
  never touch the real filesystem.
- For trace: state is serialised after each API path as `trace-<ns>-fs`; a unified
  diff is saved as `trace-<ns>-diff` for inspection; reloaded at the start of each
  path so successive operations see prior annotations.
'''
    }

    pipelineArtifacts = component "Cross-Task Artifact Handoff" {
      technology "Memory injection convention"
      description '''
- Converts upstream task artifacts into tagged memory notes (`inbox`, `previous-task-result`).
- Primary continuity mechanism between pipeline stages — tasks never share globals.
'''
    }

    templateRenderer = component "Task Template Renderer" {
      technology "str.format over YAML templates"
      description '''
- Renders task prompt text from task names, variables, params, and loaded artifact
  contents (`artifact__<safe_name>` plus a `{artifacts}` YAML dump) before each run.
- Same ADK brace pitfall applies inside `.yml` instructions as in agent prompts —
  bare `{identifier}` is interpreted as a session-state lookup.
'''
    }

    runnerCore = component "ADK Runner Core" {
      technology "google-adk Runner"
      description '''
- Executes the root agent (planner for TaskRunner, worker for AgentRunner) with
  session state, artifact service, and attached plugins.
- Produces an event stream that the CLI normalises into metrics logs and trace records.
'''
    }

    tracePlugin = component "Trace Plugin" {
      technology "ADK plugin (AdkTracePlugin)"
      description '''
- Implements before/after run and before/after tool callbacks on the ADK runner.
- Converts ADK lifecycle events into `TaskRunnerEvent`s carrying full tool-call /
  tool-result / step-level trace data (Agio event taxonomy).
'''
    }

    metricsPlugin = component "Metrics Plugin" {
      technology "ADK plugin (AdkMetricsPlugin)"
      description "Captures tool_call / tool_result / tool_exception / llm_usage / run_summary events (Agio shape); the CLI exports these to metrics.jsonl."
    }

    sessionStore = storage "Session Store" {
      technology "InMemorySessionService"
      description '''
- Per-run / per-iteration session state for ADK Runner.
- Carries state forward between iterations of the same task under
  `task::{global_task_id}::*` keys owned by the planner's tools.
'''
    }

    artifactStore = storage "Artifact Store" {
      technology "FileArtifactService"
      description '''
- Durable artifact storage keyed by app_name, user_id, and filename.
- Stores task outputs: `dependency_information/result`, `project_information/result`,
  `oas_update/result`, `oas-openapi-building`, `oas_enrich/result`,
  `likec4-architecture.c4`, …
- Also stores per-task summary/records, memory notes, trace overlay state
  (`trace-<ns>-fs`, `trace-<ns>-diff`), and `user:vulnerability-{reports,verifications}/{ns}`.
- Enables cross-task continuity without a long-lived in-memory context.
'''
    }

    localProject = storage "Target Project Directory" {
      technology "Local filesystem (rooted, read-only for oas_build/oas_update; overlaid for trace/likec4)"
      description "Repository/codebase being analysed by worker and trace agents."
    }

    outputDir = storage "Export Output Directory" {
      technology "Local filesystem"
      description '''
- Defaults to `<project>/.contractor`.
- Receives exported OpenAPI artifacts, trace diffs, intermediate files, and `metrics.jsonl` after a CLI run.
'''
    }

    litellmProxy = container "LiteLLM Proxy" {
      technology "LiteLLM + OpenAI-compatible backend"
      description '''
- Required runtime dependency, started via `deploy/litellm/run.sh` (Podman).
- Model aliases (e.g. `lm-studio-qwen3.6`) are resolved here and routed to the configured backend.
'''
    }
  }

  // ── Relationships ────────────────────────────────────────────────────────

  user -> cli "runs contractor"

  cli -> pipelineRegistry "selects pipeline class by name"
  pipelineRegistry -> buildPipeline "oas_build"
  pipelineRegistry -> enrichPipeline "oas_update"
  pipelineRegistry -> likec4Pipeline "likec4"
  pipelineRegistry -> tracePipeline "trace"
  pipelineRegistry -> traceDirectPipeline "trace-direct"
  pipelineRegistry -> traceGraphPipeline "trace-graph"
  pipelineRegistry -> traceVerifyPipeline "trace-verify"
  pipelineRegistry -> routerPipeline "router"

  cli -> outputDir "exports final artifacts and metrics.jsonl"
  cli -> litellmProxy "resolves model alias"

  buildPipeline -> taskRunner "queue dependency_information / project_information / oas_update / oas_validate"
  enrichPipeline -> artifactStore "optionally seed oas-openapi-building"
  enrichPipeline -> taskRunner "queue oas_enrich / oas_validate"

  likec4Pipeline -> overlayfs "mount overlay rooted at DEFAULT_LIKEC4_PATH"
  likec4Pipeline -> artifactStore "seed/save likec4-architecture.c4"
  likec4Pipeline -> taskRunner "queue dependency_information / project_information / likec4_build / likec4_validate"

  tracePipeline -> artifactStore "load oas-openapi-building"
  tracePipeline -> overlayfs "initialise in-memory overlay over target project"
  tracePipeline -> taskRunner "per-path: queue trace_annotation per operation"
  tracePipeline -> artifactStore "save trace-<ns>-fs and trace-<ns>-diff after each path"

  traceDirectPipeline -> artifactStore "load oas-openapi-building"
  traceDirectPipeline -> overlayfs "initialise overlay"
  traceDirectPipeline -> agentRunner "per-operation single agent invocation"
  traceDirectPipeline -> artifactStore "save trace-<ns>-fs and trace-<ns>-diff"

  traceGraphPipeline -> agentRunner "per-operation single agent invocation (with_graph_tools=True)"
  traceGraphPipeline -> overlayfs "initialise overlay"
  traceGraphPipeline -> artifactStore "save trace-<ns>-fs and trace-<ns>-diff"

  traceVerifyPipeline -> artifactStore "load per-path VulnerabilityReports"
  traceVerifyPipeline -> taskRunner "per-finding fan-out, one task per finding"

  routerPipeline -> taskRunner "single planner with router_agent as worker"
  routerPipeline -> agentRunner "trailing free-form run"

  taskRunner -> templateRenderer "render task prompt/objective"
  taskRunner -> artifactStore "load input artifacts + persist result/summary/records"
  taskRunner -> memoryTools "inject upstream artifacts as inbox / previous-task-result"
  taskRunner -> pipelineArtifacts "convert artifacts into memory handoff"
  taskRunner -> sessionStore "create/reuse per-iteration session state"
  taskRunner -> runnerCore "run planning agent (root agent)"

  agentRunner -> templateRenderer "render task prompt/objective"
  agentRunner -> sessionStore "create per-invocation session state"
  agentRunner -> runnerCore "run single worker agent as root"

  pipelineArtifacts -> memoryTools "inject upstream outputs as tagged notes"
  templateRenderer -> planningAgent "deliver rendered task objective"

  runnerCore -> planningAgent "execute planning agent as root (TaskRunner)"
  runnerCore -> traceAgent "execute trace agent as root (AgentRunner, trace-direct/graph)"
  runnerCore -> tracePlugin "emit trace callbacks"
  runnerCore -> metricsPlugin "emit Agio events"

  planningAgent -> taskTools "manage subtask state machine (add/execute/decompose/skip/finish)"
  planningAgent -> memoryTools "read/write working memory"
  planningAgent -> workerAdapter "delegate current subtask to a worker agent"

  workerAdapter -> sweAgent "wrap SWE worker"
  workerAdapter -> sweEditAgent "wrap SWE Edit worker"
  workerAdapter -> oasBuilderAgent "wrap OAS builder worker"
  workerAdapter -> oasLinterAgent "wrap OAS linter worker"
  workerAdapter -> likec4BuilderAgent "wrap LikeC4 builder worker"
  workerAdapter -> traceAgent "wrap trace worker"
  workerAdapter -> traceVerifierAgent "wrap trace verifier worker"
  workerAdapter -> httpAgent "wrap HTTP worker"
  workerAdapter -> routerAgent "wrap router worker"

  sweAgent -> fsTools "ls / glob / grep / read_file to explore codebase"
  sweAgent -> memoryTools "record findings"

  sweEditAgent -> fsTools "read + write source files (insert_line/edit/replace_range)"
  sweEditAgent -> memoryTools "record rationale"

  oasBuilderAgent -> fsTools "inspect route/controller/model files"
  oasBuilderAgent -> openapiTools "read/update OpenAPI schema state"
  oasBuilderAgent -> memoryTools "record rationale and evidence"

  oasLinterAgent -> openapiTools "audit evolving OpenAPI artifact"
  oasLinterAgent -> memoryTools "record lint findings"

  likec4BuilderAgent -> fsTools "read evidence (overlay-backed)"
  likec4BuilderAgent -> memoryTools "record rationale"
  likec4BuilderAgent -> overlayfs "write architecture.c4 in-memory"

  traceAgent -> fsTools "explore codebase via overlay (read tools + optional graph tools)"
  traceAgent -> fsTools "insert annotations (annotate_trace/validate/sink)"
  traceAgent -> memoryTools "store and retrieve findings"
  traceAgent -> vulnTools "report_vulnerability / list_vulnerabilities"
  traceAgent -> overlayfs "all writes buffered in-memory"

  traceVerifierAgent -> fsTools "read source as evidence (no writes)"
  traceVerifierAgent -> vulnTools "verify_finding / list_verifications"
  traceVerifierAgent -> memoryTools "record reasoning"

  httpAgent -> memoryTools "log probes/results"

  routerAgent -> workerAdapter "delegates to wrapped sub-agents (SWE / OAS / Trace / HTTP)"

  fsTools -> localProject "rooted read access (build/enrich)"
  fsTools -> overlayfs "copy-on-write access (trace/likec4)"
  openapiTools -> artifactStore "persist evolving OpenAPI artifact"
  memoryTools -> artifactStore "persist memory notes"
  vulnTools -> artifactStore "persist VulnerabilityReports and VerifiedFindings"

  oasAnalyzer -> artifactStore "reads inputs / emits analysis reports"
}

views {
  view systemLandscape of contractor {
    title "Contractor — system landscape"
    include *
    autoLayout lr
  }

  view containers of contractor {
    title "Contractor — containers"
    include user
    include cli
    include pipelineRegistry
    include buildPipeline
    include enrichPipeline
    include likec4Pipeline
    include tracePipeline
    include traceDirectPipeline
    include traceGraphPipeline
    include traceVerifyPipeline
    include routerPipeline
    include taskRunner
    include agentRunner
    include planningAgent
    include traceAgent
    include traceVerifierAgent
    include sweAgent
    include sweEditAgent
    include oasBuilderAgent
    include oasLinterAgent
    include likec4BuilderAgent
    include httpAgent
    include routerAgent
    include oasAnalyzer
    include runnerCore
    include litellmProxy
    include tracePlugin
    include metricsPlugin
    include sessionStore
    include artifactStore
    include overlayfs
    include outputDir
    include localProject
    autoLayout lr
  }

  view agentToolingView of contractor {
    title "Contractor — agent, tools, and storage detail"
    include planningAgent
    include traceAgent
    include traceVerifierAgent
    include sweAgent
    include oasBuilderAgent
    include likec4BuilderAgent
    include routerAgent
    include workerAdapter
    include taskTools
    include memoryTools
    include fsTools
    include openapiTools
    include vulnTools
    include overlayfs
    include pipelineArtifacts
    include artifactStore
    include localProject
    autoLayout lr
  }

  view taskLifecycleView of contractor {
