specification {
  element person
  element system
  element container
  element component
  element storage
}

model {
  user = person "CLI User" {
    description "Developer/operator invoking contractor against a local codebase."
  }

  contractor = system "Contractor" {
    description "LLM-assisted CLI for building, enriching, and security-tracing OpenAPI specifications from source code."

    cli = container "CLI" {
      technology "Python + Click"
      description '''
- Entry point exposed as the `contractor` command.
- Accepts project path, model, pipeline selection, optional artifact, folder name, and output directory.
- Validates input paths and incompatible option combinations (e.g. `--artifact` with non-enrich/trace pipelines).
- Resolves the selected model/provider route through LiteLLM-compatible configuration.
- Builds the task queue or annotation runner by selecting a pipeline builder from the registry.
- Registers on_event handlers so emitted runner/plugin events can be normalised and exported.
- Writes final artifacts and metrics.jsonl to the output directory after the run completes.
'''
    }

    pipelineRegistry = component "Pipeline Registry" {
      technology "Python functions"
      description '''
- Maps pipeline names to async builder functions.
- Current pipelines: `build`, `enrich`, `trace`.
- `build`: dependency_information -> project_information -> oas_update (SWE + OAS workers).
- `enrich`: oas_enrich seeded by an optional user-supplied OpenAPI artifact (OAS worker).
- `trace`: trace_annotation_pipeline — produces an AnnotationRunner, not a TaskRunner directly.
'''
    }

    buildPipeline = component "Build Pipeline" {
      technology "Task queue"
      description '''
- Adds `dependency_information` task using SWE worker.
- Adds `project_information` task using SWE worker with dependency artifact as input.
- Adds `oas_update` task using OAS builder worker with multiple iterations and upstream artifacts.
'''
    }

    enrichPipeline = component "Enrich Pipeline" {
      technology "Task queue"
      description '''
- Optionally pre-saves user-supplied OpenAPI text as `oas-openapi-building` artifact.
- Adds `oas_enrich` task using OAS builder worker.
'''
    }

    tracePipeline = component "Trace Pipeline" {
      technology "AnnotationRunner + TaskRunner (per operation)"
      description '''
- Implemented as `trace_annotation_pipeline` returning an `AnnotationRunner`.
- Loads an OpenAPI artifact and extracts all paths and operations.
- For each API path, calls `run_path_analysis` which spawns a TaskRunner and adds a
  `trace_annotation` task per operation.
- The TaskRunner runs the planning agent as root; the planning agent delegates annotation
  subtasks to the trace agent (wrapped as a tool via workerAdapter).
- The trace agent annotates code with structured `@trace`, `@validate`, and `@sink`
  comments and reports vulnerabilities found during execution tracing.
- After each path, saves the MemoryOverlayFileSystem state and a unified diff as artifacts.
- Operates on an in-memory overlay so the target codebase is never written to directly.
'''
    }

    taskRunner = container "TaskRunner" {
      technology "Google ADK Runner + custom orchestration"
      description '''
- Owns task queue entries with name, worker builder, params, required artifacts, iterations,
  attempts, steps, namespace, and model.
- Renders task templates before execution.
- Creates or reuses session state per task iteration.
- Loads artifacts needed by downstream tasks and injects upstream outputs as inbox /
  previous-task-result memory notes.
- Always runs the planning agent as the root agent through ADK Runner.
- Collects event streams from trace and metrics plugins.
- Persists `result`, `summary`, and `records` artifacts after each task.
- Repeats iterations when configured, allowing long tasks (e.g. OAS update) to evolve.
- Also used inside AnnotationRunner, one TaskRunner instance per API path.
'''
    }

    planningAgent = container "Planning Agent" {
      technology "Google ADK LlmAgent + LiteLLM"
      description '''
- Top-level root agent for every task across all pipelines (build, enrich, trace).
- Treats execution as a strict subtask state machine: add → execute → done/incomplete/skip.
- On incomplete: must decompose_subtask (no silent retries).
- Delegates each subtask to a worker agent (SWE, OAS Builder, or Trace) via workerAdapter.
- Workers are invoked as tools through execute_current_subtask; the planner interprets results.
- Reads and writes shared working memory via memory tools.
- Calls finish with result + summary only when the global task objective is satisfied.
- Produces `result`, `summary`, and `records` artifacts persisted by the TaskRunner.
'''
    }

    traceAgent = container "Trace Agent" {
      technology "Google ADK LlmAgent + LiteLLM"
      description '''
- Worker agent specialised in execution-path tracing and security annotation.
- Invoked by the planning agent via workerAdapter as a tool, same as SWE and OAS Builder.
- Receives a subtask with an OpenAPI operation_id and operation schema.
- Traces the request execution path through the codebase (max 3 calls deep).
- Inserts structured `@trace`, `@validate`, and `@sink` annotation comments (max 4 functions).
- Reports vulnerabilities (SQL injection, RCE, SSRF, etc.) only when a concrete
  tainted-input → sink path is confirmed by code evidence.
- Operates on MemoryOverlayFileSystem so all file writes are in-memory until explicitly saved.
- Tools: grep, ls, glob, read_file, search_def, insert_line, edit, replace_range,
  append_memory, read_memory, write_memory, list_memories, list_tags,
  interaction_stats, list_touched_files, list_untouched_files, list_match_only_files,
  report_vulnerability, list_vulnerabilities.
'''
    }

    sweAgent = container "SWE Agent" {
      technology "Google ADK LlmAgent + LiteLLM"
      description '''
- Worker agent for file-system exploration and dependency/project analysis tasks.
- Uses fs tools (ls, glob, grep, read_file) to inspect the target codebase.
- Records discovered findings via memory tools.
- Invoked by the planning agent through the WorkerAdapter.
'''
    }

    oasBuilderAgent = container "OAS Builder Agent" {
      technology "Google ADK LlmAgent + LiteLLM"
      description '''
- Worker agent specialised in constructing and updating OpenAPI specifications.
- Reads code evidence via fs tools and applies structured schema updates via openapi tools.
- Records rationale and evidence in memory tools.
- Invoked by the planning agent through the WorkerAdapter.
'''
    }

    oasAnalyzer = component "OAS Analyzer" {
      technology "Google ADK SequentialAgent"
      description '''
- Sequential agent that reviews an existing OpenAPI schema.
- Produces: service name/description/summary, data-flow diagram (Mermaid), criticality rating,
  and a list of endpoint vulnerabilities with severity and confidence scores.
- Not on the primary build/enrich/trace CLI path; invoked as an independent analysis step.
- Reads from and emits reports to the artifact store.
'''
    }

    workerAdapter = component "Worker-as-Tool Adapter" {
      technology "AgentTool wrapper"
      description '''
- Wraps a worker agent (SWE Agent, OAS Builder Agent, or Trace Agent) so the planning agent
  can invoke it via tool semantics (execute_current_subtask).
- Makes subtask execution part of the planner's tool-driven control loop across all pipelines.
'''
    }

    taskTools = component "Task Tools" {
      technology "Python functions registered as ADK tools"
      description '''
- Provides add_subtask, execute_subtask, skip_subtask, and summarise_subtask.
- Enforces the subtask state machine consumed by the planning agent.
- Includes optional summarization via a dedicated summarizer sub-agent.
- Instruments worker agents with structured input/output schemas (Subtask / SubtaskExecutionResult).
'''
    }

    memoryTools = component "Memory Tools" {
      technology "ADK artifact-backed memory"
      description '''
- Provides read/write/append/list operations on named memory notes.
- Backed by the artifact store, so memory persists across iterations of the same task.
- Used to pass context between planning agent and worker agents, and between pipeline stages.
'''
    }

    fsTools = component "File System Tools" {
      technology "RootedLocalFileSystem / MemoryOverlayFileSystem"
      description '''
- Provides ls, glob, grep, read_file for codebase exploration.
- For build/enrich pipelines: backed by RootedLocalFileSystem (read-only access).
- For trace pipeline: backed by MemoryOverlayFileSystem, allowing in-memory writes
  (annotations) without touching the real filesystem until explicitly saved.
- Also includes search_def, insert_line, edit, replace_range for trace agent writes.
'''
    }

    openapiTools = component "OpenAPI Tools" {
      technology "Structured YAML/JSON manipulation"
      description '''
- Provides read and structured-update operations on the evolving OpenAPI artifact.
- Ensures schema changes are applied consistently and persisted to the artifact store.
'''
    }

    overlayfs = storage "Memory Overlay Filesystem" {
      technology "MemoryOverlayFileSystem (in-memory)"
      description '''
- In-memory copy-on-write layer over the target project directory.
- Used exclusively by the trace pipeline so annotation writes do not touch the real filesystem.
- State is serialised to artifact store after each API path as `trace-<ns>-fs`.
- A unified diff is also saved as `trace-<ns>-diff` for inspection.
- Loaded at the start of each path analysis to resume from prior state.
'''
    }

    pipelineArtifacts = component "Cross-Task Artifact Handoff" {
      technology "Memory injection convention"
      description '''
- Converts upstream task artifacts into tagged memory notes (inbox, previous-task-result).
- Primary continuity mechanism between pipeline stages.
'''
    }

    templateRenderer = component "Task Template Renderer" {
      technology "Jinja-like templating layer"
      description '''
- Renders task prompt text from task names, variables, and params before each task run.
- Produces the concrete task objective consumed by the root agent.
'''
    }

    runnerCore = component "ADK Runner Core" {
      technology "google-adk Runner"
      description '''
- Executes the root agent with session state, artifact service, and attached plugins.
- Produces an event stream that the CLI normalises into metrics logs and trace records.
'''
    }

    tracePlugin = component "Trace Plugin" {
      technology "ADK plugin (AdkTracePlugin)"
      description '''
- Implements before/after run and before/after tool callbacks on the ADK runner.
- Converts ADK lifecycle events into TaskRunnerEvents carrying full tool-call /
  tool-result / step-level trace data.
'''
    }

    metricsPlugin = component "Metrics Plugin" {
      technology "ADK plugin"
      description "Captures metrics_* events; the CLI exports these to metrics.jsonl."
    }

    sessionStore = storage "Session Store" {
      technology "InMemorySessionService"
      description '''
- Per-run / per-iteration session state for ADK Runner.
- Carries state forward between iterations of the same task.
'''
    }

    artifactStore = storage "Artifact Store" {
      technology "FileArtifactService"
      description '''
- Durable artifact storage keyed by app_name, user_id, and filename.
- Stores task outputs: dependency_information/result, project_information/result,
  oas_update/result, oas-openapi-building, oas_enrich/result.
- Also stores summary and records payloads, memory notes, and trace overlay state
  (trace-<ns>-fs, trace-<ns>-diff).
- Enables cross-task continuity without a long-lived in-memory context.
'''
    }

    localProject = storage "Target Project Directory" {
      technology "Local filesystem (read-only for build/enrich; overlaid for trace)"
      description "Repository/codebase being analysed by worker and trace agents."
    }

    outputDir = storage "Export Output Directory" {
      technology "Local filesystem"
      description '''
- Defaults to `.contractor`.
- Receives exported OpenAPI artifacts, intermediate files, and metrics.jsonl after a CLI run.
'''
    }

    litellmProxy = container "LiteLLM Proxy" {
      technology "LiteLLM + OpenAI-compatible backend"
      description '''
- Required runtime dependency.
- Model aliases (e.g. lm-studio-qwen3.5) are resolved here and routed to the configured backend.
'''
    }

    likec4Stub = component "LikeC4 Stub Tools" {
      technology "Python dataclass placeholder"
      description '''
- `LikeC4Tools` defines: load, save, list_models, list_components, list_views.
- Not integrated into any active execution path.
'''
    }
  }

  // ── Relationships ────────────────────────────────────────────────────────

  user -> cli "runs contractor"

  cli -> pipelineRegistry "selects builder by pipeline name"
  pipelineRegistry -> buildPipeline "build"
  pipelineRegistry -> enrichPipeline "enrich"
  pipelineRegistry -> tracePipeline "trace"

  cli -> taskRunner "creates runner and enqueues tasks"
  cli -> outputDir "exports final artifacts and metrics.jsonl"
  cli -> litellmProxy "resolves model alias"

  buildPipeline -> taskRunner "queue dependency_information"
  buildPipeline -> taskRunner "queue project_information (depends on dependency artifact)"
  buildPipeline -> taskRunner "queue oas_update (depends on prior artifacts, multi-iteration)"

  enrichPipeline -> artifactStore "optionally seed oas-openapi-building"
  enrichPipeline -> taskRunner "queue oas_enrich"

  tracePipeline -> artifactStore "load oas-openapi-building"
  tracePipeline -> overlayfs "initialise in-memory overlay over target project"
  tracePipeline -> taskRunner "create per-path TaskRunner, queue trace_annotation per operation"
  tracePipeline -> artifactStore "save trace-<ns>-fs and trace-<ns>-diff after each path"

  taskRunner -> templateRenderer "render task prompt/objective"
  taskRunner -> artifactStore "load input artifacts"
  taskRunner -> memoryTools "inject upstream artifacts as prior-task memories"
  taskRunner -> pipelineArtifacts "convert artifacts into memory handoff"
  taskRunner -> sessionStore "create/reuse per-iteration session state"
  taskRunner -> runnerCore "run planning agent (root agent for all pipelines)"
  taskRunner -> artifactStore "save result/summary/records"

  pipelineArtifacts -> memoryTools "inject upstream outputs as tagged notes"

  templateRenderer -> planningAgent "deliver rendered task objective"

  runnerCore -> planningAgent "execute planning agent as root"
  runnerCore -> tracePlugin "emit trace callbacks"
  runnerCore -> metricsPlugin "emit metrics_* events"

  planningAgent -> taskTools "manage subtask state machine (add/execute/decompose/skip/finish)"
  planningAgent -> memoryTools "read/write working memory"
  planningAgent -> workerAdapter "delegate current subtask to a worker agent"

  workerAdapter -> sweAgent "wrap SWE worker"
  workerAdapter -> oasBuilderAgent "wrap OAS builder worker"
  workerAdapter -> traceAgent "wrap trace worker"

  sweAgent -> fsTools "ls / glob / grep / read_file to explore codebase"
  sweAgent -> memoryTools "record findings"

  oasBuilderAgent -> fsTools "inspect route/controller/model files"
  oasBuilderAgent -> openapiTools "read/update OpenAPI schema state"
  oasBuilderAgent -> memoryTools "record rationale and evidence"

  traceAgent -> fsTools "explore codebase via overlay (grep/ls/glob/read_file)"
  traceAgent -> fsTools "insert annotations (insert_line/edit/replace_range)"
  traceAgent -> memoryTools "store and retrieve findings"
  traceAgent -> overlayfs "all writes buffered in-memory"

  fsTools -> localProject "rooted read access (build/enrich)"
  fsTools -> overlayfs "copy-on-write access (trace)"
  openapiTools -> artifactStore "persist evolving OpenAPI artifact"
  memoryTools -> artifactStore "persist memory notes"

  oasAnalyzer -> artifactStore "reads inputs / emits analysis reports"

  likec4Stub -> artifactStore "would persist/load LikeC4 state if adopted"
}

views {
  view systemLandscape of contractor {
    title "Contractor — system landscape"
    include *
    autoLayout lr
  }

  view containers of contractor {
    title "Contractor — containers"
    include user
    include cli
    include pipelineRegistry
    include buildPipeline
    include enrichPipeline
    include tracePipeline
    include taskRunner
    include planningAgent
    include traceAgent
    include sweAgent
    include oasBuilderAgent
    include oasAnalyzer
    include runnerCore
    include litellmProxy
    include tracePlugin
    include metricsPlugin
    include sessionStore
    include artifactStore
    include overlayfs
    include outputDir
    include localProject
    autoLayout lr
  }

  view agentToolingView of contractor {
    title "Contractor — agent, tools, and storage detail"
    include planningAgent
    include traceAgent
    include sweAgent
    include oasBuilderAgent
    include workerAdapter
    include taskTools
    include memoryTools
    include fsTools
    include openapiTools
    include overlayfs
    include pipelineArtifacts
    include artifactStore
    include localProject
    autoLayout lr
  }

  view taskLifecycleView of contractor {
    title "Contractor — task lifecycle detail"
    include cli
    include buildPipeline
    include enrichPipeline
    include tracePipeline
    include taskRunner
    include taskTools
    include templateRenderer
    include planningAgent
    include workerAdapter
    include sweAgent
    include oasBuilderAgent
    include traceAgent
    include pipelineArtifacts
    include artifactStore
    include sessionStore
    autoLayout lr
  }

  view tracePipelineView of contractor {
    title "Contractor — trace pipeline detail"
    include cli
    include tracePipeline
    include taskRunner
    include planningAgent
    include workerAdapter
    include traceAgent
    include fsTools
    include memoryTools
    include overlayfs
    include artifactStore
    include localProject
    include outputDir
    autoLayout lr
  }

  view components of contractor {
    title "Contractor — key internal components"
    include cli
    include pipelineRegistry
    include buildPipeline
    include enrichPipeline
    include tracePipeline
    include taskRunner
    include templateRenderer
    include planningAgent
    include traceAgent
    include sweAgent
    include oasBuilderAgent
    include taskTools
    include memoryTools
    include fsTools
    include openapiTools
    include artifactStore
    include sessionStore
    include overlayfs
    include likec4Stub
    autoLayout lr
  }

  view fileToolsView of contractor {
    title "Contractor — file tools and repository access"
    include planningAgent
    include traceAgent
    include workerAdapter
    include sweAgent
    include oasBuilderAgent
    include fsTools
    include memoryTools
    include openapiTools
    include overlayfs
    include localProject
    include artifactStore
    autoLayout lr
  }

  view buildPipelineView of contractor {
    title "Build pipeline artifact flow"
    include buildPipeline
    include taskRunner
    include artifactStore
    include sweAgent
    include oasBuilderAgent
    autoLayout lr
  }

  view enrichPipelineView of contractor {
    title "Enrich pipeline artifact flow"
    include enrichPipeline
    include taskRunner
    include artifactStore
    include oasBuilderAgent
    autoLayout lr
  }

  dynamic buildRun {
    title "Dynamic — build pipeline run"

    user -> cli "Invoke `contractor --pipeline build`"
    cli -> pipelineRegistry "Resolve build pipeline"
    pipelineRegistry -> buildPipeline "Create build task sequence"
    buildPipeline -> taskRunner "Enqueue dependency_information"
    buildPipeline -> taskRunner "Enqueue project_information"
    buildPipeline -> taskRunner "Enqueue oas_update (multi-iteration)"
    taskRunner -> runnerCore "Run planning agent as root"
    runnerCore -> planningAgent "Execute subtask state machine"
    planningAgent -> workerAdapter "Delegate current subtask"
    workerAdapter -> sweAgent "Analyse codebase (dependency/project tasks)"
    workerAdapter -> oasBuilderAgent "Build/update OpenAPI schema (oas_update task)"
    sweAgent -> fsTools "Explore repository"
    sweAgent -> memoryTools "Record findings"
    oasBuilderAgent -> openapiTools "Persist schema updates"
    oasBuilderAgent -> memoryTools "Record rationale"
    taskRunner -> artifactStore "Save result/summary/records"
    cli -> outputDir "Export artifacts and metrics.jsonl"
  }

  dynamic traceRun {
    title "Dynamic — trace pipeline run"

    user -> cli "Invoke `contractor --pipeline trace --artifact openapi.yaml`"
    cli -> pipelineRegistry "Resolve trace pipeline"
    pipelineRegistry -> tracePipeline "Create AnnotationRunner"
    tracePipeline -> artifactStore "Load oas-openapi-building"
    tracePipeline -> overlayfs "Initialise memory overlay over project"
    tracePipeline -> taskRunner "Per-path: queue trace_annotation per operation"
    taskRunner -> runnerCore "Run planning agent as root"
    runnerCore -> planningAgent "Execute subtask state machine"
    planningAgent -> workerAdapter "Delegate trace_annotation subtask"
    workerAdapter -> traceAgent "Invoke trace worker for current operation"
    traceAgent -> fsTools "Explore codebase via overlay"
    traceAgent -> fsTools "Insert @trace/@validate/@sink annotations"
    traceAgent -> memoryTools "Record findings"
    traceAgent -> overlayfs "Buffer annotation writes in-memory"
    tracePipeline -> artifactStore "Save trace-<ns>-fs overlay state"
    tracePipeline -> artifactStore "Save trace-<ns>-diff unified diff"
    cli -> outputDir "Export annotation diffs and metrics.jsonl"
  }

  dynamic memoryHandoffRun {
    title "Dynamic — cross-task artifact handoff"

    taskRunner -> artifactStore "Load upstream task artifacts"
    taskRunner -> pipelineArtifacts "Convert artifacts to memory notes"
    pipelineArtifacts -> memoryTools "Inject notes tagged inbox/previous-task-result"
    taskRunner -> runnerCore "Run planning agent with injected memory context"
    runnerCore -> planningAgent "Planner reads prior-task context from memory"
    planningAgent -> workerAdapter "Delegate subtask to appropriate worker"
  }

  dynamic fileToolsWorkflow {
    title "Dynamic — file tools workflow"

    planningAgent -> workerAdapter "Dispatch repo-analysis subtask"
    workerAdapter -> sweAgent "Invoke SWE worker"
    sweAgent -> fsTools "ls to inspect top-level structure"
    sweAgent -> fsTools "glob to find route, handler, model, schema, and config files"
    sweAgent -> fsTools "grep to locate framework-specific signatures and endpoints"
    sweAgent -> fsTools "read_file for evidence extraction"
    sweAgent -> memoryTools "Write discovered findings and rationale"

    planningAgent -> workerAdapter "Dispatch OAS-oriented subtask"
    workerAdapter -> oasBuilderAgent "Invoke OAS builder worker"
    oasBuilderAgent -> fsTools "Inspect route/controller/model files"
    oasBuilderAgent -> openapiTools "Read current OpenAPI state"
    oasBuilderAgent -> openapiTools "Apply structured updates from file evidence"
    oasBuilderAgent -> memoryTools "Record why schema changes were made"

    planningAgent -> workerAdapter "Dispatch trace annotation subtask"
    workerAdapter -> traceAgent "Invoke trace worker"
    traceAgent -> fsTools "Explore codebase via overlay"
    traceAgent -> fsTools "Insert structured annotations into source files"
    traceAgent -> memoryTools "Record entrypoints, sinks, and validation patterns"
  }

  dynamic instrumentationFlow {
    title "Dynamic — execution tracing and metrics"

    cli -> taskRunner "Register on_event handler"
    taskRunner -> runnerCore "Attach plugins"
    runnerCore -> tracePlugin "Emit trace callbacks (before/after run and tool)"
    runnerCore -> metricsPlugin "Emit metrics_* events"
    taskRunner -> cli "Surface normalised events"
    cli -> outputDir "Write metrics.jsonl and exported artifacts"
  }
}

// Notes:
// 1. The planning agent is the single root agent for ALL pipelines (build, enrich, trace).
//    It always sits between the TaskRunner and the worker agents.
// 2. SWE Agent, OAS Builder Agent, and Trace Agent are all workers: they are wrapped by
//    workerAdapter and invoked by the planning agent via execute_current_subtask.
// 3. The `trace` pipeline is a first-class pipeline (trace_annotation_pipeline /
//    AnnotationRunner) with MemoryOverlayFileSystem and per-operation TaskRunner instances.
// 4. oasAnalyzer (SequentialAgent) remains present in code but is not on the primary CLI path.
// 5. LikeC4 tooling (likec4Stub) is still a placeholder dataclass with no active integration.
// 6. This file is hand-authored architecture documentation, not generated by the repo's own
//    LikeC4 tooling.
